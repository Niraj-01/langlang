# Claude API key for the Conversation Dojo + speak-card coaching.
# The feed / SRS reviews work fully offline without it.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (spec default: claude-sonnet-4-6)
# LANGLANG_MODEL=claude-sonnet-4-6

# Supabase backend — Google login + cross-device progress sync (optional;
# the app is fully usable local-only without these).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
